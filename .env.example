# KOSIS MCP 환경변수 설정
# 이 파일을 .env 로 복사한 뒤 값을 채워주세요
# cp .env.example .env

# KOSIS 인증키 (https://kosis.kr/openapi/ 에서 발급)
# 서버 기본 키 — URL 파라미터 kosis_key 가 없을 때 사용됩니다.
# 개인 서버라면 여기에 입력, 공개 서버라면 비워두고 각 사용자가 URL 파라미터로 전달
KOSIS_API_KEY=

# 차트 저장 경로 (로컬 실행 시)
KOSIS_OUTPUT_DIR=./kosis_charts

# 포트 (기본: 8000 / Railway·Render는 자동 주입)
PORT=8000
